From 471988250e05ff31a6002cea4fea2ed98314a7f8 Mon Sep 17 00:00:00 2001
From: Patrick Griffis <pgriffis@igalia.com>
Date: Tue, 28 Apr 2026 19:19:57 -0500
Subject: [PATCH] Fix CSSValue errors on GCC 11

---
 Source/WebCore/css/CSSValue.cpp |  5 +++++
 Source/WebCore/css/CSSValue.h   | 11 ++++++-----
 2 files changed, 11 insertions(+), 5 deletions(-)

diff --git a/Source/WebCore/css/CSSValue.cpp b/Source/WebCore/css/CSSValue.cpp
index 56a81c4d48ac..8120ca4e4db3 100644
--- a/Source/WebCore/css/CSSValue.cpp
+++ b/Source/WebCore/css/CSSValue.cpp
@@ -108,6 +108,11 @@ static_assert(sizeof(CSSValue) == sizeof(SameSizeAsCSSValue), "CSS value should
 
 DEFINE_ALLOCATOR_WITH_HEAP_IDENTIFIER(CSSValue);
 
+void CSSValue::destroy() const
+{
+    delete this;
+}
+
 template<typename Visitor> constexpr decltype(auto) CSSValue::visitDerived(Visitor&& visitor)
 {
     using enum CSSValue::ClassType;
diff --git a/Source/WebCore/css/CSSValue.h b/Source/WebCore/css/CSSValue.h
index 2f013efa886c..cc8d6afd0fbf 100644
--- a/Source/WebCore/css/CSSValue.h
+++ b/Source/WebCore/css/CSSValue.h
@@ -282,6 +282,7 @@ protected:
     // Don't go making it virtual again unless you know exactly what you're doing!
     ~CSSValue() = default;
     WEBCORE_EXPORT void operator delete(CSSValue*, std::destroying_delete_t);
+    WEBCORE_EXPORT void destroy() const;
 
     ValueSeparator separator() const { return static_cast<ValueSeparator>(m_valueSeparator); }
     static ASCIILiteral separatorCSSText(ValueSeparator);
@@ -313,15 +314,15 @@ private:
 
 inline void CSSValue::deref() const
 {
-    unsigned tempRefCount = m_refCount - refCountIncrement;
+    if (m_refCount & refCountFlagIsStatic)
+        return;
 
-    if (!tempRefCount) {
-IGNORE_GCC_WARNINGS_BEGIN("free-nonheap-object")
-        delete this;
-IGNORE_GCC_WARNINGS_END
+    if (m_refCount == refCountIncrement) {
+        destroy();
         return;
     }
 
+    unsigned tempRefCount = m_refCount - refCountIncrement;
     m_refCount = tempRefCount;
 }
 
