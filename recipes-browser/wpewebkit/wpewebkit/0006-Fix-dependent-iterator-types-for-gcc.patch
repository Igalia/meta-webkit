From 4efcedd26a84741cbc5b8e6d3ea6dbb07334ecbc Mon Sep 17 00:00:00 2001
From: Patrick Griffis <pgriffis@igalia.com>
Date: Thu, 16 Apr 2026 00:00:00 +0000
Subject: [PATCH] WebCore: fix dependent iterator types for gcc

MediaReorderQueue is a class template and iterator aliases based on
ContainerType must be prefixed with typename. Some compilers accept this
as an extension, but GCC in this build fails with:

  missing 'typename' prior to dependent type name 'ContainerType::iterator'

---
 .../platform/graphics/MediaReorderQueue.h        | 16 ++++++++--------
 1 file changed, 8 insertions(+), 8 deletions(-)

diff --git a/Source/WebCore/platform/graphics/MediaReorderQueue.h b/Source/WebCore/platform/graphics/MediaReorderQueue.h
index 0fd450bdacb3..d325ea6d5c81 100644
--- a/Source/WebCore/platform/graphics/MediaReorderQueue.h
+++ b/Source/WebCore/platform/graphics/MediaReorderQueue.h
@@ -37,14 +37,14 @@ public:
     MediaReorderQueue() = default;
 
     using ContainerType = Deque<T>;
-    ContainerType::iterator begin() LIFETIME_BOUND { return m_queue.begin(); }
-    ContainerType::iterator end() LIFETIME_BOUND { return m_queue.end(); }
-    ContainerType::const_iterator begin() const LIFETIME_BOUND { return m_queue.begin(); }
-    ContainerType::const_iterator end() const LIFETIME_BOUND { return m_queue.end(); }
-    ContainerType::reverse_iterator rbegin() LIFETIME_BOUND { return ContainerType::reverse_iterator(end()); }
-    ContainerType::reverse_iterator rend() LIFETIME_BOUND { return ContainerType::reverse_iterator(begin()); }
-    ContainerType::const_reverse_iterator rbegin() const LIFETIME_BOUND { return ContainerType::const_reverse_iterator(end()); }
-    ContainerType::const_reverse_iterator rend() const LIFETIME_BOUND { return ContainerType::const_reverse_iterator(begin()); }
+    typename ContainerType::iterator begin() LIFETIME_BOUND { return m_queue.begin(); }
+    typename ContainerType::iterator end() LIFETIME_BOUND { return m_queue.end(); }
+    typename ContainerType::const_iterator begin() const LIFETIME_BOUND { return m_queue.begin(); }
+    typename ContainerType::const_iterator end() const LIFETIME_BOUND { return m_queue.end(); }
+    typename ContainerType::reverse_iterator rbegin() LIFETIME_BOUND { return typename ContainerType::reverse_iterator(end()); }
+    typename ContainerType::reverse_iterator rend() LIFETIME_BOUND { return typename ContainerType::reverse_iterator(begin()); }
+    typename ContainerType::const_reverse_iterator rbegin() const LIFETIME_BOUND { return typename ContainerType::const_reverse_iterator(end()); }
+    typename ContainerType::const_reverse_iterator rend() const LIFETIME_BOUND { return typename ContainerType::const_reverse_iterator(begin()); }
 
     bool isEmpty() const { return m_queue.isEmpty(); }
     size_t size() const { return m_queue.size(); }
