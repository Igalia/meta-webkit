         m_lexer.next();
         VM& vm = getVM(m_globalObject);
@@ -162,8 +165,11 @@ public:
     }
 
     JSValue tryLiteralParse(JSONRanges* sourceRanges)
-        requires (reviverMode == JSONReviverMode::Enabled)
     {
+        if constexpr (reviverMode == JSONReviverMode::Disabled) {
